{
  "name": "r3gardless.dev",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "R3gardless <pidaoh@g.skku.edu>",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "bun run build:content && bun run build:meta",
    "build": "next build",
    "start": "next start",
    "export": "bun run build && touch out/.nojekyll",
    "deploy": "bun run export",
    "verify": "bun run types:check && bun run lint:check && bun run format:check && bun run test:unit:run && bun run build && bun run check-content && bun run check-repo && bun run smoke:out && bun run check-links",
    "test": "vitest",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "lint": "eslint --no-error-on-unmatched-pattern --fix \"src/**/*.{ts,tsx,js,jsx,json,md}\" \"scripts/**/*.{ts,tsx,js,jsx}\" \"tests/**/*.{ts,tsx,js,jsx}\"",
    "lint:check": "eslint --no-error-on-unmatched-pattern --cache \"src/**/*.{ts,tsx,js,jsx,json,md}\" \"scripts/**/*.{ts,tsx,js,jsx}\" \"tests/**/*.{ts,tsx,js,jsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md,css}\" \"scripts/**/*.{ts,tsx,js,jsx}\" \"tests/**/*.{ts,tsx,js,jsx,json,md,css}\" \"*.{md,json,ts,mjs}\" \".github/**/*.{yml,yaml,md}\" \".agents/**/*.md\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md,css}\" \"scripts/**/*.{ts,tsx,js,jsx}\" \"tests/**/*.{ts,tsx,js,jsx,json,md,css}\" \"*.{md,json,ts,mjs}\" \".github/**/*.{yml,yaml,md}\" \".agents/**/*.md\" \"docs/**/*.md\"",
    "types:check": "tsc --noEmit",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "sync:knowledge-base": "tsx scripts/sync-knowledge-base.ts",
    "build:content": "tsx scripts/build-content.ts",
    "build:meta": "tsx scripts/build-post-meta.ts",
    "check-content": "tsx scripts/check-content-quality.ts",
    "check-repo": "tsx scripts/check-repo-governance.ts",
    "smoke:out": "tsx scripts/smoke-build-output.ts",
    "check-links": "tsx scripts/check-links.ts"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.tsx": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{js,jsx,json,md}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.23.0",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.15.0",
    "next": "16.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-masonry-css": "^1.0.16",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-react": "^8.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "remark-wiki-link": "^2.0.1",
    "shiki": "^4.2.0",
    "typewriter-effect": "^2.22.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.0.7",
    "@storybook/addon-onboarding": "^10.0.7",
    "@storybook/builder-vite": "^10.0.7",
    "@storybook/nextjs-vite": "^10.0.7",
    "@storybook/react-vite": "^10.0.7",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/hast": "^3.0.4",
    "@types/jest": "^30.0.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.1",
    "storybook": "^10.3.1",
    "styled-jsx": "^5.1.7",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-plugin-storybook-nextjs": "^3.2.4",
    "vitest": "^4.1.0"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.0.0"
  }
}
